rv = {I: 1, V: 5, X: 10, L: 50, C: 100, D: 500, M: 1000}
fn rom s {
  cs = chars s
  tot = 0
  for p in enum cs {
    v = rv[p[1]]
    if p[0] + 1 < len cs and rv[cs[p[0] + 1]] > v { tot = tot - v }
    else { tot = tot + v }
  }
  tot
}
rs = read "roman.txt" | lines
for r in rs { print "{r} {rom r}" }
print "sum {rs | map rom | sum}"
