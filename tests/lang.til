# til language test suite — every semantic rule, as executable eg assertions.
# run: til test tests/lang.til

# -- values & arithmetic ------------------------------------------------------
eg 1 + 2 * 3 == 7
eg (1 + 2) * 3 == 9
eg 10 / 4 == 2.5
eg 7 % 3 == 1
eg -7 % 3 == 2            # floored modulo, like Python
eg 2 * -3 == -6
eg 1_000_000 == 1000000
eg 1.5e3 == 1500
eg "a" + "b" == "ab"
eg [1, 2] + [3] == [1, 2, 3]

# -- strings & interpolation --------------------------------------------------
x = 42
eg "x is {x}" == "x is 42"
eg "sum: {1 + 2}" == "sum: 3"
eg "nested {"inner {x}"}" == "nested inner 42"
eg 'raw {x} stays' == "raw \{x\} stays"
eg len "a\tb\n" == 4
eg "q\"q" == 'q"q'
eg len "hello" == 5
eg upper "til" == "TIL"
eg trim "  a  " == "a"
eg split "," "a,b,c" == ["a", "b", "c"]
eg join "-" [1, 2, 3] == "1-2-3"
eg replace "o" "0" "foo boo" == "f00 b00"
eg starts "he" "hello"
eg ends "lo" "hello"
eg rep 3 "ab" == "ababab"
eg rep 2 0 == [0, 0]
eg lines "a\nb\n" == ["a", "b"]
eg words "  the   quick  fox " == ["the", "quick", "fox"]
eg chars "ab" == ["a", "b"]
eg num "3.5" == 3.5
eg num " 12 " == 12
eg (num "nope" catch -1) == -1
eg str 3.5 == "3.5"
eg str [1, "a"] == '[1, "a"]'

# -- truthiness (Python-style) ------------------------------------------------
eg not 0
eg not ""
eg not []
eg not {}
eg not null
eg not false
eg 1 and "a" and [0] and true
eg (0 or "fallback") == "fallback"
eg (null or 5) == 5
eg (false and err "never") == false   # short-circuit: err not evaluated

# -- comparison & equality ----------------------------------------------------
eg 1 < 2 and 2 <= 2 and 3 > 2 and 3 >= 3
eg "a" < "b"
eg [1, [2, "x"]] == [1, [2, "x"]]
eg {a: 1, b: 2} == {b: 2, a: 1}      # map equality ignores order
eg 1 != "1"                          # no coercion
eg null == null

# -- lists ----------------------------------------------------------------
xs = [10, 20, 30]
eg xs[0] == 10
eg xs[-1] == 30
eg (xs[9] catch "oob") == "oob"
eg get 9 xs == null
eg get -1 xs == 30
eg first xs == 10
eg last xs == 30
eg first [] == null
eg take 2 xs == [10, 20]
eg skip 2 xs == [30]
eg take 3 "hello" == "hel"
eg rev [1, 2] == [2, 1]
eg rev "ab" == "ba"
eg range 0 4 == [0, 1, 2, 3]
eg range 3 3 == []
eg push 4 [1, 2] == [1, 2, 4]
eg flat [[1], [2, 3], 4] == [1, 2, 3, 4]
eg zip [1, 2] ["a", "b", "c"] == [[1, "a"], [2, "b"]]
eg uniq [1, 2, 1, "1", 2] == [1, 2, "1"]
eg sort [3, 1, 2] == [1, 2, 3]
eg sort ["b", "a"] == ["a", "b"]
eg sortBy {it.age} [{age: 30}, {age: 20}] == [{age: 20}, {age: 30}]
eg sortBy {-it} [1, 3, 2] == [3, 2, 1]
eg sum [1, 2, 3] == 6
eg sum [] == 0
eg min [3, 1, 2] == 1
eg max ["a", "c", "b"] == "c"
eg has 2 [1, 2]
eg 2 in [1, 2]
eg "ell" in "hello"
eg not (5 in [1, 2])
eg pos 20 xs == 1
eg pos 99 xs == null
eg pos "l" "hello" == 2

# -- higher-order + currying --------------------------------------------------
eg map {it * 2} [1, 2] == [2, 4]
eg keep {it > 1} [0, 1, 2, 3] == [2, 3]
eg fold {a b -> a + b} 0 [1, 2, 3] == 6
eg find {it > 1} [0, 1, 2] == 2
eg find {it > 9} [0, 1] == null
eg any {it == 2} [1, 2]
eg all {it > 0} [1, 2]
eg not (all {it > 1} [1, 2])
double = map {it * 2}                 # partial application: map got 1 of 2 args
eg double [1, 2] == [2, 4]
add3 = {a b c -> a + b + c}
eg add3 1 2 3 == 6
eg (add3 1) 2 3 == 6                  # explicit staged application
inc = add3 1 0
eg inc 5 == 6
eg map (add3 1 1) [1, 2] == [3, 4]

# -- pipes ----------------------------------------------------------------
eg (range 1 6 | map {it * it} | sum) == 55
eg ([3, 1, 2] | sort | rev | first) == 3
eg ("a,b,c" | split "," | len) == 3
eg (5 | add3 1 2) == 8                # pipe passes value as LAST argument
piped = range 0 10
| keep {it % 2 == 0}
| map {it * 10}
eg piped == [0, 20, 40, 60, 80]

# -- maps -------------------------------------------------------------------
# note: eg assertions run AFTER the whole file, so they see final state
m = {name: "til", "full name": "тіл", n: 1}
eg m.name == "til"
eg m["full name"] == "тіл"
eg m.missing == null
eg get "missing" m == null
eg has "name" m
eg "name" in m
m.n = 2
eg m.n == 2
m["k2"] = "v2"
eg m.k2 == "v2"
eg keys m == ["name", "full name", "n", "k2"]
eg len m == 4
eg (put "z" 9 {a: 1}) == {a: 1, z: 9}
eg (del "a" {a: 1, b: 2}) == {b: 2}
eg merge {a: 1, b: 1} {b: 2} == {a: 1, b: 2}
eg items {a: 1} == [{k: "a", v: 1}]
eg toMap [{k: "a", v: 1}] == {a: 1}
eg toMap [["x", 5]] == {x: 5}
eg vals {a: 1, b: 2} == [1, 2]
eg group {it % 3} [1, 2, 3, 4, 5] == {"1": [1, 4], "2": [2, 5], "0": [3]}
eg counts ["a", "b", "a"] == {a: 2, b: 1}

# -- json -------------------------------------------------------------------
eg json '{"a": [1, null, true]}' == {a: [1, null, true]}
eg tojson {a: 1, b: [2, "x"]} == '{"a":1,"b":[2,"x"]}'
eg (json "not json" catch "bad") == "bad"
eg json (tojson {deep: {list: [1, 2]}}) == {deep: {list: [1, 2]}}

# -- control flow -------------------------------------------------------------
eg (if 1 < 2 { "yes" } else { "no" }) == "yes"
eg (if false { 1 }) == null
eg (if false { 1 } else if true { 2 } else { 3 }) == 2

fn grade n = match n {
  n if n >= 90 -> "A"
  n if n >= 80 -> "B"
  _ -> "F"
}
eg grade 95 == "A"
eg grade 81 == "B"
eg grade 12 == "F"

fn describe_val v = match v {
  0 -> "zero"
  "" -> "empty string"
  null -> "nothing"
  true -> "yes"
  x if type x == "list" -> "list of {len x}"
  _ -> "something"
}
eg describe_val 0 == "zero"
eg describe_val "" == "empty string"
eg describe_val null == "nothing"
eg describe_val true == "yes"
eg describe_val [1, 2] == "list of 2"
eg describe_val 7 == "something"
eg (match 99 { 1 -> "a" } catch "no case") == "no case"

total = 0
for i in range 1 5 {
  total = total + i
}
eg total == 10

acc = []
for c in "ab" { acc = push c acc }
eg acc == ["a", "b"]

kv = []
for p in {a: 1, b: 2} { kv = push "{p.k}={p.v}" kv }
eg kv == ["a=1", "b=2"]

n = 0
while n < 5 { n = n + 1 }
eg n == 5

found = null
for i in range 0 100 {
  if i * i > 50 { found = i
    break }
}
eg found == 8

odds = []
for i in range 0 6 {
  if i % 2 == 0 { continue }
  odds = push i odds
}
eg odds == [1, 3, 5]

# -- functions ----------------------------------------------------------------
fn fib n {
  ensure n >= 0
  if n < 2 { n } else { fib(n - 1) + fib(n - 2) }
}
eg fib 10 == 55
eg (fib -1 catch "contract") == "contract"

fn fact n = if n <= 1 { 1 } else { n * fact(n - 1) }
eg fact 5 == 120

# mutual recursion via top-level hoisting
fn isEven n = if n == 0 { true } else { isOdd (n - 1) }
fn isOdd n = if n == 0 { false } else { isEven (n - 1) }
eg isEven 10
eg isOdd 7

fn early xs {
  for x in xs {
    if x > 10 { return x }
  }
  null
}
eg early [1, 50, 2] == 50
eg early [1, 2] == null

# closures
fn counter start {
  {  -> start }
}
c = counter 5
eg c() == 5

fn makeAdder n = {x -> x + n}
add10 = makeAdder 10
eg add10 7 == 17

# tolerated call syntax: f(a, b) works, canonical is `f a b`
eg add3(1, 2, 3) == 6
eg fib(10) == 55

# -- errors & catch -----------------------------------------------------------
eg (err "boom" catch "caught") == "caught"
eg (1 / 0 catch "div") == "div"
eg ([1][5] catch "idx") == "idx"
eg ("a" + 1 catch "type") == "type"
eg (read "/no/such/file.xyz" catch "io") == "io"
safe = json "bad" catch {}
eg safe == {}
eg ("ok" catch "unused") == "ok"

# -- push/pop mutate in place ----------------------------------------------
st = [1, 2]
push 3 st
eg st == [1, 2, 3]            # (eg sees FINAL state: 4 pushed then popped below)
alias = st
push 4 st
snap = str alias              # snapshot mid-state: push mutates, aliases see it
eg snap == "[1, 2, 3, 4]"
popped = pop st
eg popped == 4
eg st == [1, 2, 3]
eg alias == [1, 2, 3]
eg pop [] == null

# -- multi-assignment (simultaneous, Python-style) --------------------------
p, q = 1, 2
pq1 = [p, q]
p, q = q, p
eg pq1 == [1, 2]
eg [p, q] == [2, 1]
fa, fb = 0, 1
fa, fb = fb, fa + fb
fa, fb = fb, fa + fb
eg [fa, fb] == [1, 2]
mm = {a: 0}
mm.a, mm["b"] = 7, 8
eg mm == {a: 7, b: 8}

# -- elif ------------------------------------------------------------------
fn sign n = if n > 0 { "pos" } elif n < 0 { "neg" } else { "zero" }
eg sign 3 == "pos"
eg sign -3 == "neg"
eg sign 0 == "zero"

# -- stats builtins -----------------------------------------------------------
eg mean [1, 2, 3, 4] == 2.5
eg median [3, 1, 2] == 2
eg median [4, 1, 3, 2] == 2.5
eg stdev [2, 2, 2] == 0
eg stdev [2, 4, 4, 4, 5, 5, 7, 9] == 2
eg (mean [] catch "empty") == "empty"

# -- top ---------------------------------------------------------------------
eg top 2 {a: 3, b: 9, c: 5} == [{k: "b", v: 9}, {k: "c", v: 5}]
eg top 1 (counts ["x", "y", "x"]) == [{k: "x", v: 2}]
eg top 9 {a: 1} == [{k: "a", v: 1}]
eg (["b", "a", "b", "a", "c"] | counts | top 2) == [{k: "b", v: 2}, {k: "a", v: 2}]  # ties keep first-seen order

# -- enum -------------------------------------------------------------------
eg enum ["a", "b"] == [[0, "a"], [1, "b"]]
eg enum [] == []
eg enum "hi" == [[0, "h"], [1, "i"]]
eg (enum ["x", "y"] | keep {p -> p[0] > 0} | map {p -> p[1]}) == ["y"]

# -- rounding is half-up (documented divergence from python's banker's) -----
eg roundTo 2 0.125 == 0.13
eg roundTo 0 2.5 == 3

# -- negative-argument heuristic (Ruby-style) -----------------------------
eg abs -3 == 3            # space before -, none after → negative argument
eg get -1 [7, 8] == 8
a = 10
eg a - 3 == 7             # spaced both sides → subtraction
eg a-3 == 7               # tight both sides → subtraction
eg 5 - -2 == 7

# -- misc builtins --------------------------------------------------------
eg type 1 == "num"
eg type "s" == "str"
eg type [1] == "list"
eg type {} == "map"
eg type null == "null"
eg type true == "bool"
eg type print == "fn"
eg empty []
eg empty ""
eg empty null
eg not (empty [1])
eg abs -3 == 3
eg round 2.5 == 3
eg roundTo 2 3.14159 == 3.14
eg floor 2.9 == 2
eg ceil 2.1 == 3
eg sqrt 16 == 4
eg pow 2 10 == 1024

# -- print returns its value (tap-through) -------------------------------
# (print output goes to host; value passes through pipes)
eg ([1, 2] | sum) == 3

# -- cyclic structures: safe display/equality, catchable serialization -----
cyc = {}
cyc.self = cyc
eg str cyc == "\{self: <cycle>}"
eg (tojson cyc catch "cyclic") == "cyclic"
cyc2 = {}
cyc2.self = cyc2
eg cyc == cyc2
cylist = [1]
push cylist cylist
eg str cylist == "[1, <cycle>]"

# -- deep recursion raises catchable E_STACK, never a raw crash ------------
fn boom n = boom (n + 1)
eg (boom 0 catch "deep") == "deep"

# -- match binds into the enclosing scope (Python-style) -------------------
match 5 { bound -> { doubled = bound * 2 } }
eg bound == 5
eg doubled == 10

# -- lambda as a match-case body ------------------------------------------
fmatch = match 1 {
  1 -> {x -> x * 2}
  _ -> null
}
eg fmatch 21 == 42

# -- regex: rall / rmatch / rsub (JS syntax, catchable) ---------------------
# patterns go in raw '…' strings so regex \w etc never fight til escapes
log = "ERROR disk at 10:31, WARN net at 10:45, ERROR cpu at 11:02"
eg rall 'ERROR \w+' log == ["ERROR disk", "ERROR cpu"]
eg rmatch '\d+:\d+' log == "10:31"
eg rmatch 'FATAL' log == null
eg rsub '\d+:\d+' "<t>" log == "ERROR disk at <t>, WARN net at <t>, ERROR cpu at <t>"
eg rsub '(\w+)@(\w+)' "$2.$1" "user@host" == "host.user"
eg rall 'x' "" == []
eg (rall '(' "oops" catch "bad-re") == "bad-re"
eg (rall '[a-z]+' "AB cd EF gh" | join ",") == "cd,gh"

# -- strings are code points, not UTF-16 units ------------------------------
emo = "😀🙂"
eg len emo == 2
eg emo[0] == "😀"
eg emo[-1] == "🙂"
eg take 1 emo == "😀"
eg skip 1 emo == "🙂"
eg rev emo == "🙂😀"
eg get 1 emo == "🙂"
eg chars emo == ["😀", "🙂"]
eg pos "🙂" emo == 1
