{
  "name": "vscode-til",
  "displayName": "til \u2014 \u0442\u0456\u043b",
  "description": "Syntax highlighting for the til scripting language (.til files).",
  "version": "0.2.1",
  "publisher": "til-lang",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "til",
        "aliases": [
          "til"
        ],
        "extensions": [
          ".til"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "til",
        "scopeName": "source.til",
        "path": "./syntaxes/til.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "til.run",
        "title": "til: run current file"
      }
    ],
    "configuration": {
      "title": "til",
      "properties": {
        "til.path": {
          "type": "string",
          "default": "",
          "description": "path to the til CLI (bin/til); empty = auto-detect"
        }
      }
    }
  },
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:til"
  ]
}